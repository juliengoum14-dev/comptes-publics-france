{
  "name": "comptes-publics-france",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard des recettes et dépenses publiques de la France — visualisation et analyse des finances de l'État et des APU",
  "scripts": {
    "dev": "next dev",
    "build": "bash safe-build.sh next build",
    "start": "next start",
    "lint": "eslint",
    "refresh-data": "bash scripts/refresh-data.sh",
    "prepare": "husky",
    "test:smoke": "node .opencode/smoke-test.mjs",
    "test:prod": "BASE_URL=${BASE_URL} npx playwright test e2e/prod-smoke.spec.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@stripe/stripe-js": "^5",
    "@supabase/supabase-js": "^2",
    "dotenv": "^16.6.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2"
  },
  "optionalDependencies": {
    "@supabase/ssr": "^0",
    "stripe": "^17"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9",
    "lint-staged": "^15",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
