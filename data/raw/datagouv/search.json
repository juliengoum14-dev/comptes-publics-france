io.cloud.ovh.net/ac/83f761a23f4263be8b3401b01625e8-100.png", "name": "Cour des comptes", "page": "https://www.data.gouv.fr/organizations/cour-des-comptes", "permissions": {"delete": false, "edit": false, "harvest": false, "members": false, "private": false}, "slug": "cour-des-comptes", "uri": "https://www.data.gouv.fr/api/1/organizations/cour-des-comptes/"}, "owner": null, "page": "https://www.data.gouv.fr/datasets/les-finances-publiques-locales-2015-1", "permissions": {"delete": false, "edit": false, "edit_resources": false}, "private": false, "quality": {"dataset_description_quality": true, "license": true, "score": 0.2222222222222222, "spatial": false, "temporal_coverage": false, "update_frequency": false}, "resources": [], "schema": null, "slug": "les-finances-publiques-locales-2015-1", "spatial": null, "tags": [], "temporal_coverage": null, "title": "Les finances publiques locales (2015)", "uri": "https://www.data.gouv.fr/api/1/datasets/les-finances-publiques-locales-2015-1/"}, {"access_audiences": [], "access_type": "open", "access_type_reason": null, "access_type_reason_category": null, "acronym": null, "archived": null, "authorization_request_url": null, "badges": [], "contact_points": [], "created_at": "2015-10-19T16:35:14.047000+00:00", "deleted": null, "description": "La Cour des comptes a rendu public, le 13 octobre 2015, un rapport sur les finances publiques locales, fruit d\u2019un travail commun avec les chambres r\u00e9gionales des comptes, sur la situation financi\u00e8re et la gestion des collectivit\u00e9s territoriales et de leurs \u00e9tablissements publics. Les administrations publiques locales (Apul) repr\u00e9sentent 20 % de la d\u00e9pense et 9 % de la dette publiques. Elles sont concern\u00e9es par le respect des engagements europ\u00e9ens de la France en vue du redressement de ses comptes publics.\n\nCe rapport est accessible sur le [site de la Cour](https://www.ccomptes.fr/fr/publications/les-finances-publiques-locales-2015).\n\nLes fichiers publi\u00e9s correspondent aux donn\u00e9es ayant servi de base \u00e0 l'\u00e9laboration du rapport, qui seul engage les juridictions financi\u00e8res. La mise \u00e0 disposition de ces donn\u00e9es compl\u00e8te l'offre d'information \u00e0 destination des citoyens. ", "description_short": null, "extras": {}, "featured": false, "frequency": "unknown", "frequency_date": "2015-10-19T00:00:00+00:00", "harvest": null, "id": "5624ffa2c751df7df7bd3534", "internal": {"created_at_internal": "2015-10-19T16:35:14.047000+00:00", "last_modified_internal": "2017-09-12T10:12:48.872000+00:00"}, "last_modified": "2017-09-12T10:12:48.872000+00:00", "last_update": "2017-09-12T10:12:48.872000+00:00", "license": "odc-odbl", "metrics": {"dataservices": 0, "discussions": 1, "discussions_open": 1, "followers": 0, "followers_by_months": {"2024-08": 0, "2024-09": 0, "2024-10": 0, "2024-11": 0, "2024-12": 0, "2025-01": 0, "2025-02": 0, "2025-03": 0, "2025-04": 0, "2025-05": 0, "2025-06": 0, "2025-07": 0, "2025-08": 0}, "resources_downloads": 220, "reuses": 0, "reuses_by_months": {"2024-08": 0, "2024-09": 0, "2024-10": 0, "2024-11": 0, "2024-12": 0, "2025-01": 0, "2025-02": 0, "2025-03": 0, "2025-04": 0, "2025-05": 0, "2025-06": 0, "2025-07": 0, "2025-08": 0}, "views": 2587}, "organization": {"acronym": null, "badges": [{"kind": "public-service"}, {"kind": "certified"}], "class": "Organization", "id": "53698dada3a729239d20331d", "logo": "https://udata-avatars.s3.rbx.io.cloud.ovh.net/ac/83f761a23f4263be8b3401b01625e8.png", "logo_thumbnail": "https://udata-avatars.s3.rbx.io.cloud.ovh.net/ac/83f761a23f4263be8b3401b01625e8-100.png", "name": "Cour des comptes", "page": "https://www.data.gouv.fr/organizations/cour-des-comptes", "permissions": {"delete": false, "edit": false, "harvest": false, "members": false, "private": false}, "slug": "cour-des-comptes", "uri": "https://www.data.gouv.fr/api/1/organizations/cour-des-comptes/"}, "owner": null, "page": "https://www.data.gouv.fr/datasets/les-finances-publiques-locales-2015", "permissions": {"delete": false, "edit": false, "edit_resources": false}, "private": false, "quality": {"all_resources_available": false, "dataset_description_quality": true, "has_open_format": true, "has_resources": true, "license": true, "resources_documentation": false, "score": 0.4444444444444444, "spatial": true, "temporal_coverage": false, "update_frequency": false}, "resources": [{"checksum": null, "created_at": "2017-07-12T15:13:25.859000+00:00", "description": null, "extras": {"check:available": false, "check:count-availability": 273, "check:date": "2026-02-12T11:07:51.562510+00:00", "check:error": "Not Found", "check:headers:charset": "utf-8", "check:headers:content-type": "text/html", "check:id": 41382419, "check:status": 404, "check:timeout": false, "check:url": "https://www.ccomptes.fr/sites/default/files/EzPublish/Rapport+FPL2015.zip"}, "filesize": null, "filetype": "remote", "format": "zip (csv utf8)", "harvest": null, "id": "e7dec1e9-5322-4976-8562-9998111386e3", "internal": {"created_at_internal": "2017-07-12T15:13:25.859000+00:00", "last_modified_internal": "2017-09-12T10:12:48.872000+00:00"}, "last_modified": "2017-09-12T10:12:48.872000+00:00", "latest": "https://www.data.gouv.fr/api/1/datasets/r/e7dec1e9-5322-4976-8562-9998111386e3", "metrics": {"nb_hits": 0, "nb_uniq_visitors": 0, "nb_visits": 0, "views": 248}, "mime": null, "preview_url": null, "schema": null, "title": "Les finances publiques locales 2015", "type": "main", "url": "https://www.ccomptes.fr/sites/default/files/EzPublish/Rapport+FPL2015.zip"}], "schema": null, "slug": "les-finances-publiques-locales-2015", "spatial": {"geom": null, "granularity": "other", "zones": []}, "tags": ["apul", "collectivites-territoriales", "finances-locales"], "temporal_coverage": null, "title": "Les finances publiques locales 2015", "uri": "https://www.data.gouv.fr/api/1/datasets/les-finances-publiques-locales-2015/"}, {"access_audiences": [], "access_type": "open", "access_type_reason": null, "access_type_reason_category": null, "acronym": null, "archived": null, "authorization_request_url": null, "badges": [], "contact_points": [], "created_at": "2017-10-11T10:52:17.467000+00:00", "deleted": null, "description": "La Cour des comptes rend public son cinqui\u00e8me rapport annuel sur la situation financi\u00e8re et la gestion des collectivit\u00e9s territoriales. Ce rapport, destin\u00e9 au Parlement et au Gouvernement, est le fruit d\u2019un travail commun avec les chambres r\u00e9gionales des comptes (CRC).\nLes administrations publiques locales, qui repr\u00e9sentent 18 % de la d\u00e9pense publique, sont concern\u00e9es, au m\u00eame titre que l\u2019\u00c9tat et les organismes de s\u00e9curit\u00e9 sociale, par le respect des engagements europ\u00e9ens de la France en vue du redressement de ses comptes publics.\nEn 2016, leurs d\u00e9penses ont diminu\u00e9 de 1,1 % alors que leurs recettes ont progress\u00e9 de 0,2 %. Pour la seconde ann\u00e9e cons\u00e9cutive, elles ont d\u00e9gag\u00e9 une capacit\u00e9 de financement, qui a atteint 4,2 Md\u20ac apr\u00e8s 1,1 Md\u20ac en 2015, ce qui traduit une am\u00e9lioration de leur situation financi\u00e8re.\n\nCe rapport est accessible sur [le site de la Cour](https://www.ccomptes.fr/fr/publications/les-finances-publiques-locales-2017).\n\nLes fichiers publi\u00e9s correspondent aux donn\u00e9es ayant servi de base \u00e0 l'\u00e9laboration du rapport.", "description_short": null, "extras": {}, "featured": false, "frequency": "unknown", "frequency_date": null, "harvest": null, "id": "59dddbc1c751df5c158f083b", "internal": {"created_at_internal": "2017-10-11T10:52:17.467000+00:00", "last_modified_internal": "2017-10-11T10:52:51.574000+00:00"}, "last_modified": "2017-10-11T10:52:51.574000+00:00", "last_update": "2018-09-19T14:56:05+00:00", "license": "odc-odbl", "metrics": {"dataservices": 0, "discussions": 0, "discussions_open": 0, "followers": 0, "followers_by_months": {"2024-08": 0,